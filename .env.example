# ===== Antigravity Bot Configuration =====
# Copy this file to .env and fill in your values.

# Telegram Bot Token (get from @BotFather)
BOT_TOKEN=your_bot_token_here

# Your Telegram Chat ID (send /start to get it, leave empty to allow all)
ALLOWED_CHAT_ID=

# Chrome DevTools Protocol port (must match IDE launch args)
DEBUGGING_PORT=9333

# Language: en | tr
LANGUAGE=en

# Optional: Custom projects directory (defaults to ~/Projects)
# PROJECTS_DIR=/home/user/Projects
