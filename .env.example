# ===== Antigravity Telegram Suite Configuration =====
# Copy this file to .env and fill in your values.

# Telegram Bot Token (get from @BotFather)
BOT_TOKEN=your_bot_token_here

# Google OAuth API Credentials (REQUIRED for the Google Login function to work)
# 
# 💡 How this behaves:
# - These credentials are required for the Google OAuth login flow (/login) to work.
# - Use these exact base64 values below to make the default Antigravity Enterprise integration work.
#
GOOGLE_CLIENT_ID=MTA3MTAwNjA2MDU5MS10bWhzc2luMmgyMWxjcmUyMzV2dG9sb2poNGc0MDNlcC5hcHBzLmdvb2dsZXVzZXJjb250ZW50LmNvbQ==
GOOGLE_CLIENT_SECRET=R09DU1BYLUs1OEZXUjQ4NkxkTEoxbUxCOHNYQzR6NnFEQWY=

# Your Telegram Chat ID(s) (send /start to get it)
# For multiple users, separate with commas: 123456,789012
ALLOWED_CHAT_ID=

# CDP Debugging Ports (must match IDE launch args)
# If running both apps side-by-side, use different ports
AGENT_CDP_PORT=9333
IDE_CDP_PORT=9334

# Default AI model to select on new chat / IDE startup
DEFAULT_MODEL=Gemini 3.5 Flash (Medium)

# Language: en | zh | ko | tr | de | es | fr
LANGUAGE=en

# Optional: Custom projects directory (defaults to ~/Projects)
# PROJECTS_DIR=/home/user/Projects

# ===== Project Memory Convention =====
# When enabled, switching workspace (/workspace) ensures the target project has a
# lightweight "Project Memory" section in its CLAUDE.md / AGENT.md / GEMINI.md
# (whichever exists, else AGENT.md is created). Agents are nudged to record durable
# decisions/conventions/gotchas/fixes directly in that file by editing it — no MCP
# server, vector DB, or extra tool calls required. Off by default; idempotent once added.
AUTO_MEMORY_CONVENTION=false

# ===== Antigravity Dual App Configuration =====
# Preferred active application target: 'agent' (standalone Antigravity) or 'ide' (Antigravity IDE)
ANTIGRAVITY_PREFERRED_APP=ide

# Optional: Custom Windows executable paths
# ANTIGRAVITY_AGENT_PATH=C:\Users\YourUsername\AppData\Local\Programs\Antigravity\Antigravity.exe
# ANTIGRAVITY_IDE_PATH=C:\Users\YourUsername\AppData\Local\Programs\Antigravity-IDE\Antigravity-IDE.exe

# Enable auto-accept module by default when the bot starts
AUTOACCEPT_DEFAULT=true

# ===== Quota Display Filter =====
# Controls which models appear in /getinfo output.
# Matched case-insensitively against each model's displayName (substring match).
# Separate entries with commas. Remove or leave blank to show ALL models.
# Each entry below is commented with its typical display name for reference.
#
# ── Claude ──────────────────────────────────────────────────────────
# Claude Opus 4.6 (Thinking)
# Claude Sonnet 4.6 (Thinking)
# Claude Haiku 3.5 (Fast)
#
# ── Gemini 3.x ──────────────────────────────────────────────────────
# Gemini 3 Flash
# Gemini 3.1 Flash Lite        (lite / budget tier)
# Gemini 3.1 Flash Image       (multimodal)
# Gemini 3.1 Pro (High)        (pro high-quality)
# Gemini 3.1 Pro (Low)         (pro cost-efficient)
# Gemini 3.5 Flash (High)      (flash high-quality)
# Gemini 3.5 Flash (Low)       (flash cost-efficient)
# Gemini 3.5 Flash (Medium)    (flash balanced)
#
# ── Gemini 2.x ──────────────────────────────────────────────────────
# Gemini 2.5 Pro               (previous-gen pro)
# Gemini 2.5 Flash             (previous-gen flash)
#
# ── GPT / Other ─────────────────────────────────────────────────────
# GPT-OSS 120B (Medium)
#
QUOTA_DISPLAY_MODELS=Claude Opus 4.6,Claude Sonnet 4.6,Gemini 3.5 Flash (High),Gemini 3.5 Flash (Low),Gemini 3.5 Flash (Medium),Gemini 3.1 Pro (High),Gemini 3.1 Pro (Low)

# ===== Telegraph Publishing =====
# API host for Telegraph uploads. api.graph.org is the default community mirror
# used because api.telegra.ph (.ph TLD) is blocked on many networks/hosts.
# Switch to api.telegra.ph only if graph.org is unreachable from your server.
# TELEGRAPH_API_HOST=api.graph.org

# ===== Turbo Mode Model Configuration =====
# Defines which models are used during each phase of Turbo Mode.
# If Claude hits a quota limit or times out, it automatically falls back to the specified fallback model.
TURBO_PHASE1_MODEL=Gemini 3.5 Flash (High)
TURBO_PHASE1_FALLBACK=Claude Opus 4.6 (Thinking)
TURBO_PHASE2_MODEL=Gemini 3.1 Pro (High)
TURBO_PHASE3_MODEL=Gemini 3.5 Flash (High)
TURBO_PHASE3_FALLBACK=Claude Opus 4.6 (Thinking)
TURBO_PHASE4_MODEL=Gemini 3.1 Pro (High)
TURBO_PHASE5_MODEL=Gemini 3.5 Flash (High)
